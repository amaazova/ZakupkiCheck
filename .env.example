# OpenRouter API — единый шлюз ко всем LLM-провайдерам
OPENROUTER_API_KEY=your_openrouter_key_here

# Основная модель сервиса и research-пайплайна
PRIMARY_MODEL=deepseek/deepseek-v4-flash

# Дополнительные модели — нужны только для воспроизведения ablation A5 (multi-model)
# SONNET_MODEL=anthropic/claude-sonnet-4.6
# QWEN_MODEL=qwen/qwen3-max

# Опциональные ключи — нужны только если вы запускаете соответствующие провайдеры напрямую,
# минуя OpenRouter. По умолчанию research-пайплайн использует OpenRouter.
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Пути к локальному корпусу. Используются ETL-скриптами (etl/scripts/) при сборе.
# Сервисное приложение и research-пайплайн читают только sample-данные из data/.
# DATA_DIR=
# RAG_DIR=
